#include <math.h>
#include <stdio.h>
#include "stm32f4xx_hal.h"
#include "qmcr5883l.h"
#include "mpu6050_port.h"

extern I2C_HandleTypeDef hi2c1;

// -------------------------- AUTO-ZERO VARIABLES ---------------------------
int offset_calibrated = 0;
float heading_offset = 0.0f;

// -------------------------- HARD-IRON CALIBRATION --------------------------
float mag_min[3] = {  99999,  99999,  99999 };
float mag_max[3] = { -99999, -99999, -99999 };
float hardiron_offset[3] = {0};
int hardiron_calibrated = 0;

// Call this for every magnetometer sample BEFORE offset subtraction
void hardiron_collect_samples(float mx, float my, float mz)
{
    if (mx < mag_min[0]) mag_min[0] = mx;
    if (my < mag_min[1]) mag_min[1] = my;
    if (mz < mag_min[2]) mag_min[2] = mz;

    if (mx > mag_max[0]) mag_max[0] = mx;
    if (my > mag_max[1]) mag_max[1] = my;
    if (mz > mag_max[2]) mag_max[2] = mz;
}

// Call once after rotating sensor 360° slowly
void hardiron_compute_offset(void)
{
    hardiron_offset[0] = (mag_max[0] + mag_min[0]) / 2.0f;
    hardiron_offset[1] = (mag_max[1] + mag_min[1]) / 2.0f;
    hardiron_offset[2] = (mag_max[2] + mag_min[2]) / 2.0f;

    hardiron_calibrated = 1;

    printf("Hard-iron offsets -> X: %.2f Y: %.2f Z: %.2f\r\n",
            hardiron_offset[0], hardiron_offset[1], hardiron_offset[2]);
}

// -------------------------- I2C HELPERS --------------------------
void qmc_i2c_write(uint8_t reg_addr, uint8_t value)
{
    HAL_I2C_Mem_Write(&hi2c1, (QMC_ADDR << 1), reg_addr,
                      I2C_MEMADD_SIZE_8BIT, &value, 1, 50);
}

uint8_t qmc_i2c_read(uint8_t reg_addr)
{
    uint8_t value = 0;
    HAL_I2C_Mem_Read(&hi2c1, (QMC_ADDR << 1), reg_addr,
                     I2C_MEMADD_SIZE_8BIT, &value, 1, 50);
    return value;
}

// ------------------------ RETURN DEGREE NORMALIZATION -----------------------
float calibrate_heading(float current_heading, float heading_offset)
{
    float calibrated_heading = current_heading - heading_offset;

    if (calibrated_heading < 0.0f)
        calibrated_heading += 360.0f;
    else if (calibrated_heading >= 360.0f)
        calibrated_heading -= 360.0f;

    return calibrated_heading;
}

// -------------------------- MAIN MAG READ FUNCTION --------------------------
float qmc_mag_read(void)
{
    float mag_x, mag_y, mag_z;
    uint8_t Rec_Data[6];
    float angle;
    float pitch_rad, roll_rad;

    // Read raw magnetometer registers
    Rec_Data[0] = qmc_i2c_read(0x02); // X MSB
    Rec_Data[1] = qmc_i2c_read(0x01); // X LSB
    Rec_Data[2] = qmc_i2c_read(0x04); // Y MSB
    Rec_Data[3] = qmc_i2c_read(0x03); // Y LSB
    Rec_Data[4] = qmc_i2c_read(0x06); // Z MSB
    Rec_Data[5] = qmc_i2c_read(0x05); // Z LSB

    // Make signed 16-bit values
    mag_x = (int16_t)(Rec_Data[0] << 8 | Rec_Data[1]);
    mag_y = (int16_t)(Rec_Data[2] << 8 | Rec_Data[3]);
    mag_z = (int16_t)(Rec_Data[4] << 8 | Rec_Data[5]);

    // Collect samples for hard-iron calibration
    hardiron_collect_samples(mag_x, mag_y, mag_z);

    // Apply hard-iron correction AFTER min/max found
    if (hardiron_calibrated) {
        mag_x -= hardiron_offset[0];
        mag_y -= hardiron_offset[1];
        mag_z -= hardiron_offset[2];
    }

    // Get tilt angles (in radians)
    pitch_rad = mpu_accel_read(1) * (3.14159f / 180.0f);
    roll_rad  = -mpu_accel_read(0) * (3.14159f / 180.0f);

    // Tilt compensation
    float Xh = mag_x * cosf(pitch_rad) + mag_z * sinf(pitch_rad);
    float Yh = mag_x * sinf(roll_rad) * sinf(pitch_rad)
             + mag_y * cosf(roll_rad)
             - mag_z * sinf(roll_rad) * cosf(pitch_rad);

    angle = atan2f(Yh, Xh) * (180.0f / 3.14159f);
    if (angle < 0.0f)
        angle += 360.0f;

    // Auto-zero on first run only
    if (!offset_calibrated) {
        heading_offset = angle;
        offset_calibrated = 1;
        printf("Compass auto-zeroed. Offset = %.2f°\r\n", heading_offset);
    }

    // Return in radians
    return angle * (3.14159f / 180.0f);
}

// ---------------------- Initialization -----------------------------
void qmc_init(void)
{
    qmc_i2c_write(0x0B, 0x08);   // Control 2
    qmc_i2c_write(0x0A, 0xCD);   // 200Hz, full-scale mode

    printf("QMC5883L initialized.\r\n");
}
