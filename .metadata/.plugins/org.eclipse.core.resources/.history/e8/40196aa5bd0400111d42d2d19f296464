uint32_t mapRCtoMotor(uint16_t rcValue) {
	if (rcValue > 2000) {
		rcValue = 2000;
	}
	if (rcValue < 1000) {
		rcValue = 1000;
	}
	// used simple ratio vala logic (y-0/63000-0 = x-1000 / 2000-1000)
	uint32_t motorValue = (uint32_t) (rcValue - 1000) * 180 / 1000;
	return motorValue;
}
